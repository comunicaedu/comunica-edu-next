{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Iniciar Servidor ComunicaEDU",
      "type": "shell",
      "command": "node start-dev.js",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting",
          "endsPattern": "Ready"
        }
      }
    }
  ]
}
